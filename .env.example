# OpenAI API key (server-side only). Used as a second-opinion layer on trade signals.
OPENAI_API_KEY="sk-..."

# Optional: default model for second-opinion calls (override in code default if unset).
# OPENAI_MODEL="gpt-4o-mini"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Persistent runtime state directory.
# On Render, mount a Persistent Disk and set this to the mount path (for example /var/data).
# Leave unset for local development; it will default to ./data.
DATA_DIR=""

# Optional strict state protection.
# If true with BINANCE_ENABLED=true, startup fails when no valid local state exists.
# Leave false/unset on ephemeral hosts if you want the bot to keep trading after restarts.
REQUIRE_PERSISTED_STATE_ON_LIVE=false

# ── Binance Live Trading ────────────────────────────────────────────────────
# Master switch. Set to "true" to activate real order placement.
# Leave unset or "false" to stay in paper trading mode (safe default).
BINANCE_ENABLED=false

# Binance USDT-M Futures API credentials.
# Create at: https://www.binance.com/en/my/settings/api-management
# Required permissions: Futures trading (read + trade). Do NOT enable withdrawals.
BINANCE_API_KEY=""
BINANCE_API_SECRET=""

# Set to "false" only when you are ready for real money.
# Default is "true" (testnet). Testnet API base: https://demo-fapi.binance.com
BINANCE_TESTNET=true
